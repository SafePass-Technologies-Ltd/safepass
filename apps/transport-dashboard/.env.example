# SafePass Transport Dashboard — Environment Variables
# Copy to .env.local (gitignored) and fill in real values.

# Backend API — production: https://api.safepass-tech.com (NOT the
# dashboard's own domain, and NOT plain http:// once the ALB enforces TLS).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Reserved: this dashboard has no WebSocket-driven feature yet (unlike
# admin-dashboard/corporate-dashboard's live trip maps) -- no code reads
# this today. Set it anyway if/when a live-tracking view is added here, to
# the same value as the other dashboards: wss://api.safepass-tech.com/v1/ws
# NEXT_PUBLIC_WS_URL=

# Firebase Web SDK (client-side auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
