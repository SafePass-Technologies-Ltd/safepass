{
  "name": "@safepass/api",
  "version": "0.1.0",
  "private": true,
  "description": "SafePass REST + WebSocket API (Hono on Node.js)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node ../../scripts/fix-esm-extensions.mjs dist",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.826.0",
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/client-secrets-manager": "^3.826.0",
    "@aws-sdk/lib-dynamodb": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "@hono/node-server": "1.13.0",
    "@hono/zod-validator": "0.8.0",
    "@safepass/shared": "workspace:*",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "0.28.1",
    "drizzle-orm": "0.45.2",
    "firebase-admin": "13.4.0",
    "hono": "4.12.0",
    "hono-rate-limiter": "^0.5.3",
    "ioredis": "5.6.1",
    "jose": "6.2.0",
    "node-cron": "^4.6.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.0",
    "postgres": "3.4.5",
    "resend": "^6.12.4",
    "uuid": "11.1.0",
    "ws": "^8.21.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.15.0",
    "@types/uuid": "10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "4.19.0",
    "typescript": "5.8.3",
    "vitest": "3.2.0"
  }
}
