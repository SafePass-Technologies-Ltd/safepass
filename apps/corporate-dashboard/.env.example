# SafePass Corporate Dashboard — Environment Variables
# Copy to .env.local (gitignored) and fill in real values.

# Backend API — production: https://api.safepass-tech.com (NOT the
# dashboard's own domain, and NOT plain http:// once the ALB enforces TLS).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# WebSocket endpoint (see src/app/dashboard/map/page.tsx) — production:
# wss://api.safepass-tech.com/v1/ws. Missing/wrong value here means the
# live map's WebSocket connection never opens and the UI shows a
# permanent "Reconnecting..." state (silent, no error surfaced).
NEXT_PUBLIC_WS_URL=ws://localhost:3000/v1/ws

# Firebase Web SDK (client-side auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
