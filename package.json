{
  "name": "safepass",
  "version": "0.1.0",
  "private": true,
  "description": "SafePass — Road safety, trip monitoring, and incident intelligence for Nigeria",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "3.4.0",
    "turbo": "2.9.16",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
