# =============================================================================
# SafePass — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env or secrets to version control.
# =============================================================================

# === Node Environment ===
NODE_ENV=development

# === Database (PostgreSQL 16) ===
DATABASE_URL=postgresql://safepass:safepass_dev@localhost:5432/safepass

# === Redis (Upstash) ===
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=

# === DynamoDB (real-time state -- GPS positions) ===
# Points at docker-compose's DynamoDB Local; omit in production to use real
# AWS DynamoDB via the ECS task role. Table name matches env.ts's default,
# self-created by the app on boot only when DYNAMODB_ENDPOINT is set (see
# apps/api/src/services/dynamo.service.ts).
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=eu-west-2
DYNAMODB_TABLE_NAME=safepass-development-realtime-state

# === Auth — JWT (generate with: openssl rand -hex 64) ===
JWT_ACCESS_SECRET=change-me-access-secret-64-chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-64-chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === Firebase Admin SDK (for backend token verification) ===
FIREBASE_PROJECT_ID=safepass-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# === Firebase Web SDK (for client-side auth in dashboards) ===
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === API ===
API_BASE_URL=http://localhost:3000
API_PORT=3000

# === Frontend URLs ===
ADMIN_DASHBOARD_URL=http://localhost:3001
CORPORATE_DASHBOARD_URL=http://localhost:3002
TRANSPORT_DASHBOARD_URL=http://localhost:3003

# Base URL for org invite deep links (C-02) -- appended with /<token>.
# Production: https://api.safepass-tech.com/join
APP_DEEP_LINK_BASE_URL=http://localhost:3000/join

# === Payment Gateways ===
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-

# === Google Maps Platform ===
GOOGLE_MAPS_API_KEY=
# Client-side key for Next.js dashboards (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# === AWS (S3 — evidence + document storage) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET=safepass-dev

# === Push Notifications (Firebase Cloud Messaging) ===
# Uses the same Firebase project as auth

# === SMS (Twilio / Africa's Talking) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# === Email (Resend — role upgrade approval/rejection notices) ===
RESEND_API_KEY=
EMAIL_FROM=SafePass <onboarding@resend.dev>

# === Trip Pricing ===
TRIP_PRICE_NGN=2000

# === Feature Flags ===
ENABLE_PANIC_RECORDING=true
ENABLE_CORPORATE_DASHBOARD=false
ENABLE_TRANSPORT_DASHBOARD=false


FACEBOOK_APP_ID=